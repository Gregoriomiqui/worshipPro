rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isMemberOf(organizationId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/organizations/$(organizationId)/members/$(request.auth.uid));
    }
    
    function isAdminOf(organizationId) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/organizations/$(organizationId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    function hasValidPendingInvitation(invitationId, organizationId) {
      return invitationId is string &&
             exists(/databases/$(database)/documents/invitations/$(invitationId)) &&
             get(/databases/$(database)/documents/invitations/$(invitationId)).data.organizationId == organizationId &&
             get(/databases/$(database)/documents/invitations/$(invitationId)).data.email == request.auth.token.email &&
             get(/databases/$(database)/documents/invitations/$(invitationId)).data.status == 'pending';
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read/write their own document
      allow read, write: if isAuthenticated() && request.auth.uid == userId;

      // Allow admins to remove a user from an organization they manage
      allow update: if isAuthenticated() &&
                       request.resource.data.removeOrganizationId is string &&
                       isAdminOf(request.resource.data.removeOrganizationId) &&
                       resource.data.organizationIds.hasAny([
                         request.resource.data.removeOrganizationId
                       ]) &&
                       !request.resource.data.organizationIds.hasAny([
                         request.resource.data.removeOrganizationId
                       ]) &&
                       request.resource.data.organizationIds.size() ==
                           resource.data.organizationIds.size() - 1 &&
                       request.resource.data.email == resource.data.email &&
                       request.resource.data.displayName == resource.data.displayName &&
                       request.resource.data.photoURL == resource.data.photoURL &&
                       request.resource.data.activeOrganizationId ==
                           resource.data.activeOrganizationId &&
                       request.resource.data.authProviders ==
                           resource.data.authProviders &&
                       request.resource.data.createdAt == resource.data.createdAt;
      
      // Allow reading specific fields for invitations
      allow get: if isAuthenticated();
    }
    
    // Organizations collection
    match /organizations/{organizationId} {
      // Read: if user is member
      allow read: if isMemberOf(organizationId);
      
      // Create: any authenticated user (when creating new org)
      allow create: if isAuthenticated() && 
                       request.resource.data.createdBy == request.auth.uid;
      
      // Update/Delete: only admins
      allow update, delete: if isAdminOf(organizationId);
      
      // Members subcollection
      match /members/{memberId} {
        // Read: if user is member of the organization
        allow read: if isMemberOf(organizationId);
        
        // Create: admins, OR the org creator adding themselves as first member,
        // OR invitee accepting a valid pending invitation
        allow create: if isAdminOf(organizationId) || 
                         (isAuthenticated() && 
                          get(/databases/$(database)/documents/organizations/$(organizationId)).data.createdBy == request.auth.uid &&
                          memberId == request.auth.uid) ||
                         (isAuthenticated() &&
                          memberId == request.auth.uid &&
                          request.resource.data.email == request.auth.token.email &&
                          hasValidPendingInvitation(request.resource.data.invitationId, organizationId));
        
        // Update/Delete: only admins
        allow update, delete: if isAdminOf(organizationId);
      }
      
      // Liturgies subcollection
      match /liturgias/{liturgyId} {
        // Read/Write: if user is member of the organization
        allow read, write: if isMemberOf(organizationId);
        
        // Bloques subcollection
        match /bloques/{blockId} {
          allow read, write: if isMemberOf(organizationId);
          
          // Canciones subcollection
          match /canciones/{songId} {
            allow read, write: if isMemberOf(organizationId);
          }
        }
      }
    }
    
    // Invitations collection
    match /invitations/{invitationId} {
      // Read: if addressed to the user's email
      allow read: if isAuthenticated() && 
                     request.auth.token.email == resource.data.email;
      
      // Create: only admins of the organization
      allow create: if isAuthenticated() && 
                       isAdminOf(request.resource.data.organizationId);
      
      // Update: user can accept/reject their own invitation
      allow update: if isAuthenticated() && 
                       request.auth.token.email == resource.data.email;
      
      // Delete: admins can delete invitations
      allow delete: if isAuthenticated() && 
                       isAdminOf(resource.data.organizationId);
    }
  }
}